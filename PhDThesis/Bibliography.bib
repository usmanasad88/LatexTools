   pages = {128-144},
   publisher = {Index Copernicus},
   title = {DIGITAL TWIN BASED SYNCHRONISED CONTROL AND SIMULATION 
OF THE INDUSTRIAL ROBOTIC CELL USING VIRTUAL REALITY},
   volume = {19},
   url = {https://jme.publisherspanel.com/gicid/01.3001.0013.0464},
   year = {2019},
}

