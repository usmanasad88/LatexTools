\includegraphics [width=4.5in, height=4in]{ThesisFigs/Fig2_2.pdf}
\caption{$f_{max}$ and $f_T$ as a function of $L_g$.}
\label{Fig:2.2}
\end{figure}

\begin{figure}
\centering
%\includegraphics [scale=0.5]{3D}
\includegraphics [width=4.5in, height=4in]{ThesisFigs/Fig2_3.pdf}
