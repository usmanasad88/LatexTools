\centering
\footnotesize
\renewcommand{\arraystretch}{1.5}
\renewcommand{\tabcolsep}{0.25cm}
\caption{Physical parameters of a submicron SiC MESFET.}
\begin{tabular}{llll}
\hline
\textbf{Parameters} & \textbf{Value}   & \textbf{Parameters} & \textbf{Value} \\
\hline
$\varepsilon_0$ &8.85 $\times$ 10$^{-12}$ Fm$^{-1}$  &$V_{bi}$  &1.1eV\\
%\hline
