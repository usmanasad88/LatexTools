\begin{tabular}{l|l}
\hline
\textbf{Parameters} & \textbf{Values}\\
\hline
$\mu_{min}$ &40 cm${^2}$/V-s\\
%\hline
$\mu_{max}$ &950 cm${^2}$/V-s\\
%\hline
$N_{ref}$ &1 $\times$ 10$^{17}$ cm$^{-3}$\\
%\hline
$N_{d}$ &1.7 $\times$ 10$^{17}$ cm$^{-3}$\\
%\hline
$\alpha$ &2.6\\
\hline
